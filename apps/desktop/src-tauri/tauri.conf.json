{
  "productName": "Omega",
  "version": "1.5.0",
  "identifier": "com.omega.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://omega-chat-five.vercel.app",
    "beforeBuildCommand": "",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Ω OMEGA",
        "width": 1200,
        "height": 800,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "open-url",
          "cmd": "open",
          "args": true
        }
      ]
    },
    "notification": {
      "all": true
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$HOME/**"],
        "deny": []
      }
    }
  }
}
